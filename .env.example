# PaperSeek example environment file.
# Copy to .env for local CLI use, or set these variables in your shell.
# Do not commit real API keys.

DATA_SOURCE=openalex

# LLM provider settings.
# ModelScope API-Inference example:
# LLM_PROVIDER=modelscope
# LLM_API_TYPE=openai_chat
# LLM_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507
# LLM_BASE_URL=https://api-inference.modelscope.cn/v1
LLM_PROVIDER=deepseek
LLM_API_TYPE=openai_chat
LLM_MODEL=deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=

# OpenAlex is the default source. API key is recommended for stable use.
OPENALEX_API_KEY=
OPENALEX_EMAIL=

# Crossref public API usually needs only a polite-pool email.
CROSSREF_EMAIL=

# Web of Science Starter requires an approved Clarivate API key.
WOS_API_KEY=
WOS_DB=WOS

# Search behavior.
SEARCH_FIELD=
TARGET_MIN=5
TARGET_MAX=50
MAX_ITERATIONS=5
EXPAND_CITATIONS=true
FETCH_ABSTRACTS=false
CITATION_SEED_COUNT=3
CITATION_PER_SEED=4
CITATION_MAX_RECORDS=40

# Local open-source history. Keys are never stored in this SQLite database.
PAPERSEEK_HISTORY_ENABLED=true
# PAPERSEEK_DATA_DIR=~/.paperseek
# PAPERSEEK_HISTORY_DB=~/.paperseek/paperseek.db
